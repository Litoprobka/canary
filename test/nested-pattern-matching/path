type Either a b = L a | R b

e1 = Either Int Int
e2 = Either e1 e1
e3 = Either e2 e2

test : e3 -> Int
test = match
    (L (L (L _))) -> 1
    (L (L (R _))) -> 2
    (L (R (L _))) -> 3
    (L (R (R _))) -> 4
    (R (L (L _))) -> 5
    (R (L (R _))) -> 6
    (R (R (L _))) -> 7
    (R (R (R _))) -> 8

testCase : e3 -> Int
testCase e = case e of
    L (L (L _)) -> 1
    L (L (R _)) -> 2
    L (R (L _)) -> 3
    L (R (R _)) -> 4
    R (L (L _)) -> 5
    R (L (R _)) -> 6
    R (R (L _)) -> 7
    R (R (R _)) -> 8